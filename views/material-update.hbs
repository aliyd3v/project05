<main class="app-main">
    <div class="app-content-header"> <!--begin::Container-->
        <div class="container-fluid"> <!--begin::Row-->
            <div class="row">
                {{#if alert}}
                {{#if alert.success}}
                <div class="alert alert-success" id="alert" role="alert">
                    {{alert.message}}
                </div>
                {{else}}
                <div class="alert alert-danger" id="alert" role="alert">
                    {{alert.message}}
                </div>
                {{/if}}
                {{else}}
                {{/if}}
            </div>
        </div> <!--end::Container-->
    </div>
    <div class="app-content">
        <div class="container-fluid">
            <div class="row g-4">
                <div class="col-md-6">
                    <div class="card card-warning card-outline mb-4">
                        <div class="card-header">
                            <div class="card-title">Update Material</div>
                        </div>
                        <form id="update-form" action="/api/material/{{material.id}}/update" method="POST">
                            <div class="card-body">
                                <div class="row mb-3">
                                    <label for="name" class="col-sm-2 col-form-label">Name</label>
                                    <div class="col-sm-10">
                                        <input type="text" class="form-control" id="name" name="name" value="{{material.name}}" required>
                                    </div>
                                </div>
                                <div class="row mb-3">
                                    <label for="quantity" class="col-sm-2 col-form-label">Quantity</label>
                                    <div class="col-sm-10">
                                        <input type="number" class="form-control" id="quantity" name="quantity" value="{{material.quantity}}" required>
                                    </div>
                                </div>

                                <div class="button-container mb-4">
                                    <button type="button" class="btn btn-danger" data-bs-toggle="modal" data-bs-target="#deleteModal">
                                        Delete
                                    </button>
                                    <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#quantityModal">
                                        Add / Remove Quantity
                                    </button>
                                </div>

                                <div class="update-cancel-container d-flex justify-content-between">
                                    <button type="submit" class="btn btn-warning">Update</button>
                                    <a href="/api/materials" class="btn btn-light">Cancel</a>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Delete Modal oyna -->
    <div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="deleteModalLabel">Tasdiqlash</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    Ushbu materialni o'chirishga ishonchingiz komilmi?
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Bekor qilish</button>
                    <form id="delete-form" action="/api/material/{{material.id}}/delete" method="POST">
                        <button type="submit" class="btn btn-danger">O'chirish</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Quantity Modal oyna -->
    <div class="modal fade" id="quantityModal" tabindex="-1" aria-labelledby="quantityModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="quantityModalLabel">Quantity Qo'shish / O'chirish</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <!-- Add Quantity form -->
                    <form id="add-quantity-form" action="/api/material/{{material.id}}/add" method="POST" class="mb-3">
                        <div class="mb-3">
                            <label for="addQuantityInput" class="form-label">Quantity Qo'shish</label>
                            <input type="number" class="form-control" id="addQuantityInput" name="quantity" required>
                        </div>
                        <button type="submit" class="btn btn-success w-100">Add</button>
                    </form>

                    <!-- Remove Quantity form -->
                    <form id="remove-quantity-form" action="/api/material/{{material.id}}/reduce" method="POST">
                        <div class="mb-3">
                            <label for="removeQuantityInput" class="form-label">Quantity O'chirish</label>
                            <input type="number" class="form-control" id="removeQuantityInput" name="quantity" required>
                        </div>
                        <button type="submit" class="btn btn-warning w-100">Remove</button>
                    </form>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Bekor qilish</button>
                </div>
            </div>
        </div>
    </div>
</main>

<script>
    let alert = document.getElementById('alert')
    setTimeout(() => {
        alert.style.display = "none"
    }, 3000)
</script>