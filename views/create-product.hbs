<style>
/* Responsiv dizayn uchun qo'shimcha uslublar */
.table-responsive {
    display: block;
    width: 100%;
    overflow-x: auto;
}

@media (max-width: 768px) {
    .card {
        margin: 0 auto;
        width: 100%;
    }
    
    .table-responsive {
        font-size: 0.9em;
    }
    
    /* Qatorlar va ustunlar orasidagi masofani sozlash */
    th, td {
        padding: 8px 5px;
        text-align: center;
    }
}
</style>

<!--begin::App Main-->
<main class="app-main"> <!--begin::App Content-->
    <div class="app-content"> <!--begin::Container-->
        <div class="container-fluid"> <!--begin::Row-->
            <div class="row">
                {{#if alert}}
                {{#if alert.success}}
                <div class="alert alert-success" id="alert" role="alert">
                    {{alert.message}}
                </div>
                {{else}}
                <div class="alert alert-danger" id="alert" role="alert">
                    {{alert.message}}
                </div>
                {{/if}}
                {{else}}
                {{/if}}
            </div> <!--end::Row-->
            <div class="row g-4"> <!--begin::Col-->
                <div class="col-12">
                </div> <!--end::Col--> <!--begin::Col-->
                <div class="col-md-6"> <!--begin::Horizontal Form-->
                    <div class="card card-warning card-outline mb-4"> <!--begin::Header-->
                        <div class="card-header">
                            <div class="card-title">Add product</div>
                        </div> <!--end::Header--> <!--begin::Form-->
                        <form action="/api/create-product" method="post"> <!--begin::Body-->
                            <div class="card-body">
                                <div class="row mb-3"> <label for="name" class="col-sm-2 col-form-label">Name</label>
                                    <div class="col-sm-10"> <input type="text" class="form-control" name="name"
                                            id="name" required> </div>
                                </div>
                                <div class="app-content"> <!--begin::Container-->
                                    <div class="container-fluid">
                                        <!--begin::Row-->
                                     <div class="row">
    <div class="card mb-4">
        <div class="card-header">
            <h4 class="card-title">Materials for using.</h4>
        </div> <!-- /.card-header -->
        <div class="card-body p-0">
            <table class="table table-responsive">
                <thead>
                    <tr>
                        <th style="width: 33%; text-align: center;">Select</th>
                        <th style="width: 33%; text-align: center;">Material Name</th>
                        <th style="width: 33%; text-align: center;">Amount</th>
                    </tr>
                </thead>
                <tbody>
                    {{#each materials}}
                    <tr>
                        <!-- Materialni tanlash uchun checkbox -->
                        <td style="text-align: center;">
                            <input type="checkbox" name="materialIds" value="{{this.id}}"
                                onchange="toggleAmountInput(this)">
                        </td>
                        <!-- Material nomi -->
                        <td style="text-align: center;">{{this.name}}</td>
                        <!-- Miqdor kiritish uchun input -->
                        <td style="text-align: center;">
                            <input type="number" step="any" name="amount-{{this.id}}"
                                placeholder="Enter amount" disabled>
                        </td>
                    </tr>
                    {{/each}}
                </tbody>
            </table>
        </div> <!-- /.card-body -->
    </div> <!-- /.card -->
</div> <!--end::Row-->
                                    </div> <!--end::Container-->
                                </div> <!--end::App Content-->
                            </div> <!--end::Body--> <!--begin::Footer-->
                            <div class="card-footer"> <button type="submit" class="btn btn-warning">Add</button> <a
                                    class="btn float-end" href="/api/products">Cancel</a> </div> <!--end::Footer-->
                        </form> <!--end::Form-->
                    </div> <!--end::Horizontal Form-->
                </div> <!--end::Col-->
            </div> <!--end::Row-->
        </div> <!--end::Container-->
    </div> <!--end::App Content-->
</main> <!--end::App Main-->

<script>
    function toggleAmountInput(checkbox) {
        const materialId = checkbox.value;
        const amountInput = document.querySelector(`input[name="amount-${materialId}"]`);
        amountInput.disabled = !checkbox.checked; // Checkbox tanlanganda input faollashadi
    }
</script>