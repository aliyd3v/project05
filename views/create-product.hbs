<!--begin::App Main-->
<main class="app-main"> <!--begin::App Content-->
    <div class="app-content"> <!--begin::Container-->
        <div class="container-fluid"> <!--begin::Row-->
            <div class="row">
                {{#if alert}}
                {{#if alert.success}}
                <div class="alert alert-success" id="alert" role="alert">
                    {{alert.message}}
                </div>
                {{else}}
                <div class="alert alert-danger" id="alert" role="alert">
                    {{alert.message}}
                </div>
                {{/if}}
                {{else}}
                {{/if}}
            </div> <!--end::Row-->
            <div class="row g-4"> <!--begin::Col-->
                <div class="col-12">
                </div> <!--end::Col--> <!--begin::Col-->
                <div class="col-md-6"> <!--begin::Horizontal Form-->
                    <div class="card card-warning card-outline mb-4"> <!--begin::Header-->
                        <div class="card-header">
                            <div class="card-title">Add product</div>
                        </div> <!--end::Header--> <!--begin::Form-->
                        <form action="/api/create-product" method="post"> <!--begin::Body-->
                            <div class="card-body">
                                <div class="row mb-3"> <label for="name" class="col-sm-2 col-form-label">Name</label>
                                    <div class="col-sm-10"> <input type="text" class="form-control" name="name"
                                            id="name" required> </div>
                                </div>
                                <div class="app-content"> <!--begin::Container-->
                                    <div class="container-fluid">
                                        <!--begin::Row-->
                                        <div class="row">
                                            <div class="card mb-4">
                                                <div class="card-header">
                                                    <h4 class="card-title">Materials for using.</h4>
                                                </div> <!-- /.card-header -->
                                                <div class="card-body p-0">
                                                    <table class="table" id="materialsTable">
                                                        <thead>
                                                            <tr>
                                                                <th style="width: 20%; margin: 0 auto;">Material name
                                                                </th>
                                                                <th style="width: 20%; margin: 0 auto;">Amount for using
                                                                </th>
                                                                <th style="width: 10%; margin: 0 auto;">Actions</th>
                                                            </tr>
                                                        </thead>
                                                        <tbody id="materialsBody">
                                                            <tr id="noMaterialsMessage">
                                                                <td colspan="3" style="text-align: center;">Materials is
                                                                    empty!</td>
                                                            </tr>
                                                        </tbody>
                                                    </table>
                                                    <div class="d-flex justify-content-center my-2">
                                                        <button type="button" class="btn btn-primary" id="addMaterialBtn">Add
                                                            Material</button>
                                                    </div>
                                                </div> <!-- /.card-body -->
                                            </div> <!-- /.card -->
                                        </div> <!--end::Row-->
                                    </div> <!--end::Container-->
                                </div> <!--end::App Content-->

                                <script>
                                    document.getElementById('addMaterialBtn').addEventListener('click', function () {
                                        const noMaterialsMessage = document.getElementById('noMaterialsMessage');
                                        if (noMaterialsMessage) noMaterialsMessage.style.display = 'none';

                                        const newRow = document.createElement('tr');
                                        newRow.innerHTML = `
            <td>
                <select id="materialSelect" class="form-select">
                    <option value="">Select material</option>
                    {{#each materials}}
                    <option value="{{this.id}}">{{this.name}}</option>
                    {{/each}}
                </select>
            </td>
            <td>
                <input type="number" id="amountInput" class="form-control" min="1" placeholder="Enter amount">
            </td>
            <td>
                <button class="btn btn-success" id="confirmAddBtn">&#10003;</button>
            </td>
        `;

                                        document.getElementById('materialsBody').appendChild(newRow);

                                        document.getElementById('confirmAddBtn').addEventListener('click', function () {
                                            const materialSelect = document.getElementById('materialSelect');
                                            const amountInput = document.getElementById('amountInput');
                                            const selectedMaterial = materialSelect.options[materialSelect.selectedIndex].text;
                                            const selectedValue = materialSelect.value;
                                            const amount = amountInput.value;

                                            if (selectedValue && amount) {
                                                const confirmedRow = document.createElement('tr');
                                                confirmedRow.innerHTML = `
                    <td>${selectedMaterial}</td>
                    <td>${amount}</td>
                    <td>
                        <button class="btn btn-danger deleteBtn">Delete</button>
                    </td>
                `;
                                                document.getElementById('materialsBody').replaceChild(confirmedRow, newRow);

                                                confirmedRow.querySelector('.deleteBtn').addEventListener('click', function () {
                                                    confirmedRow.remove();
                                                    if (!document.querySelector('#materialsBody tr')) {
                                                        noMaterialsMessage.style.display = 'table-row';
                                                    }
                                                });
                                            } else {
                                                alert('Please select a material and enter an amount.');
                                            }
                                        });
                                    });
                                </script>

                            </div> <!--end::Body--> <!--begin::Footer-->
                            <div class="card-footer"> <button type="submit" class="btn btn-warning">Add</button> <a
                                    class="btn float-end" href="/api/products">Cancel</a> </div> <!--end::Footer-->
                        </form> <!--end::Form-->
                    </div> <!--end::Horizontal Form-->
                </div> <!--end::Col-->
            </div> <!--end::Row-->
        </div> <!--end::Container-->
    </div> <!--end::App Content-->
</main> <!--end::App Main-->