<!--begin::App Main-->
<main class="app-main"> <!--begin::App Content-->
    <div class="app-content"> <!--begin::Container-->
        <div class="container-fluid"> <!--begin::Row-->
            <div class="row g-4"> <!--begin::Col-->
                {{#if alert}}
                {{#if alert.success}}
                <div class="alert alert-success" id="alert" role="alert">
                    {{alert.message}}
                </div>
                {{else}}
                <div class="alert alert-danger" id="alert" role="alert">
                    {{alert.message}}
                </div>
                {{/if}}
                {{else}}
                {{/if}}
                <div class="col-12">
                </div> <!--end::Col--> <!--begin::Col-->
                <div class="col-md-6"> <!--begin::Horizontal Form-->
                    <div class="card card-warning card-outline mb-4"> <!--begin::Header-->
                        <div class="card-header">
                            <div class="card-title">Update used materials for {{data.name}}</div>
                        </div> <!--end::Header--> <!--begin::Form-->
                        <form action="/api/user/{{data._id}}/update" method="post"> <!--begin::Body-->
                            <div class="card-body">
                                <div class="card-body p-0">
                                    <table class="table">
                                        <thead>
                                            {{#if data.materialsUsed}}
                                            <tr>
                                                <th style="width: 20%; margin: 0 auto;">Material
                                                    name</th>
                                                <th style="width: 20%; margin: 0 auto;">Amount used
                                                </th>
                                            </tr>
                                            {{/if}}
                                        </thead>
                                        <tbody>
                                            {{#if data.materialsUsed}}
                                            {{#each data.materialsUsed}}
                                            <tr class="align-middle" id="{{id}}"
                                                style="{user-select: none; cursor: pointer;}">
                                                <td>{{name}}</td>
                                                <td>{{amount}} gr</td>
                                            </tr>
                                            {{/each}}
                                            {{else}}
                                            <p style="font-size: x-large; text-align: center;">
                                                Products is empty!</p>
                                            {{/if}}
                                        </tbody>
                                    </table>
                                </div> <!-- /.card-body -->
                            </div> <!--end::Body--> <!--begin::Footer-->
                            <div class="card-footer"> <button type="submit" class="btn btn-warning">Update</button> <a
                                    class="btn float-end" href="/api/product/{{data._id}}">Cancel</a> </div>
                            <!--end::Footer-->
                        </form> <!--end::Form-->
                    </div> <!--end::Horizontal Form-->
                </div> <!--end::Col-->
            </div> <!--end::Row-->
        </div> <!--end::Container-->
    </div> <!--end::App Content-->
</main> <!--end::App Main-->

<script>
    let alert = document.getElementById('alert')
    setTimeout(() => {
        alert.style.display = "none"
    }, 3000)
</script>