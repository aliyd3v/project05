<!DOCTYPE html>
<html lang="uz">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <title>Login Page</title>
    <style>
        /* Umumiy tanlangan CSS */
        body {
            font-family: Arial, sans-serif;
            margin: 0;
            padding: 0;
            background-color: #f2f2f2;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
        }

        .login-container {
            background-color: #fff;
            padding: 15px; /* Paddingni kamaytirdik */
            border-radius: 8px; /* Burchaklarni biroz kichikroq qildik */
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
            max-width: 300px; /* Kenglikni kichikroq qildik */
            width: 100%;
        }

        h2 {
            text-align: center;
            margin-bottom: 15px; /* H2 uchun bo'shliqni kamaytirdik */
        }

        .input-group {
            margin-bottom: 10px; /* Input guruhlarining oraliqlarini kamaytirdik */
        }

        label {
            display: block;
            margin-bottom: 4px; /* Label uchun bo'shliqni kamaytirdik */
            font-weight: bold;
        }

        input[type="text"],
        input[type="password"] {
            width: 100%;
            padding: 8px; /* Inputlar uchun paddingni kamaytirdik */
            font-size: 14px; /* Shriftni kichikroq qildik */
            border: 1px solid #ccc;
            border-radius: 5px;
            box-sizing: border-box;
        }

        .btn {
            width: 100%;
            padding: 8px; /* Tugmani kichikroq qildik */
            background-color: #4CAF50;
            color: white;
            border: none;
            border-radius: 5px;
            font-size: 14px; /* Tugma shriftini ham kichikroq qildik */
            cursor: pointer;
        }

        .btn:hover {
            background-color: #45a049;
        }
    </style>
</head>
<body>

    <div class="login-container">
        <h2>Login</h2>
        <form action="/api/auth/login" method="POST" autocomplete="on">
            <div class="input-group">
                <label for="username">Username</label>
                <input type="text" id="username" name="username" required autocomplete="username">
            </div>
            <div class="input-group">
                <label for="password">Password</label>
                <input type="password" id="password" name="password" required autocomplete="current-password">
            </div>
            <button type="submit" class="btn">Login</button>
        </form>
    </div>

</body>
</html>
