<div class="material-details">
    <h1>Material Details</h1>
    <div class="material-info">
        <p><strong>Name:</strong> <span id="material-name">{{material.name}}</span></p>
        <p><strong>Quantity:</strong> <span id="material-quantity">{{material.quantity}}</span></p>
    </div>

    <div id="edit-form" class="edit-modal" style="display: none;">
        <form action="/api/update-material/{{material.id}}" method="post">
        <h2>Edit Material</h2>
        <label for="edit-name">Name:</label>
        <input type="text" id="edit-name" name="name" value="{{material.name}}">
        <label for="edit-quantity">Quantity:</label>
        <input type="number" id="edit-quantity" name="quantity" value="{{material.quantity}}">
        <button class="update-button" onclick="updateMaterial('{{material.id}}')">Update</button>
        <button class="cancel-edit" onclick="cancelEdit()">Cancel</button>
        </form>
    </div>

    <div class="action-buttons">
        <button class="edit-button" onclick="openEditForm()">Edit</button>
        <button class="delete-button" onclick="confirmDelete('{{id}}', '{{name}}')">Delete</button>
    </div>

    <a href="/api/materials" class="back-button">Back to Materials</a>

    <div id="delete-confirmation" class="confirmation-modal" style="display: none;">
        <form action="/api/delete-material/{{material.id}}" method="post">
        <h2>Confirm Deletion</h2>
        <p>Are you sure you want to delete this material: <strong>{{material.name}}</strong>?</p>
        <button class="confirm-delete" onclick="deleteMaterial('{{material.id}}')">Yes, Delete</button>
        <button class="cancel-delete" onclick="cancelDelete()">Cancel</button>
        </form>
    </div>
</div>




<script>
function confirmDelete(materialId, materialName) {
    const confirmationModal = document.getElementById('delete-confirmation');
    confirmationModal.style.display = 'block'; // Modalni ko'rsatish
}

function cancelDelete() {
    const confirmationModal = document.getElementById('delete-confirmation');
    confirmationModal.style.display = 'none'; // Modalni yashirish
}

function deleteMaterial(materialId) {
    // O'chirish yo'nalishiga yo'naltirish
    window.location.href = `/api/delete-material/${materialId}`;
}

function openEditForm() {
    // Material ma'lumotlarini inputlarga joylash
    document.getElementById('edit-name').value = document.getElementById('material-name').innerText;
    document.getElementById('edit-quantity').value = document.getElementById('material-quantity').innerText;
    
    // Edit formani ko'rsatish
    document.getElementById('edit-form').style.display = 'block';

    // Material info ni yashirish
    document.querySelector('.material-info').style.display = 'none';
}

function cancelEdit() {
    // Edit formani yashirish
    document.getElementById('edit-form').style.display = 'none';
    
    // Material info ni ko'rsatish
    document.querySelector('.material-info').style.display = 'block';
}

</script>
