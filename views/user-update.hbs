    <div class="update-user-container">
        <h2 class="update-user-title">Update User</h2>
        <form class="update-user-form" action="#" method="POST">
            <div class="update-user-info">
                <div class="update-user-item">
                    <label for="name" class="update-user-label">Name:</label>
                    <input type="text" id="name" name="name" required class="update-user-input" placeholder="Ismingizni kiriting">
                </div>
                <div class="update-user-item">
                    <label for="username" class="update-user-label">Username:</label>
                    <input type="text" id="username" name="username" required class="update-user-input" placeholder="Foydalanuvchi nomini kiriting">
                </div>
            </div>
            <div class="update-user-button-group">
                <button type="submit" class="update-user-save-button">Save</button>
                <a href="#" class="update-user-cancel-button">Cancel</a>
            </div>
            <div class="update-password-link">
                <a href="#" class="update-password-button">Update Password</a>
            </div>
        </form>
        <form action="#" method="POST" class="delete-user-form">
            <button type="submit" class="update-user-delete-button">Delete</button>
        </form>
    </div>