<!--begin::App Main-->
<main class="app-main"> <!--begin::App Content-->
  <div class="app-content"> <!--begin::Container-->
    <div class="container-fluid"> <!--begin::Row-->
      <div class="row g-4"> <!--begin::Col-->
                {{#if alert}}
                {{#if alert.success}}
                <div class="alert alert-success" id="alert" role="alert">
                    {{alert.message}}
                </div>
                {{else}}
                <div class="alert alert-danger" id="alert" role="alert">
                    {{alert.message}}
                </div>
                {{/if}}
                {{else}}
                {{/if}}
        <div class="col-12">
        </div> <!--end::Col--> <!--begin::Col-->
        <div class="col-md-6"> <!--begin::Horizontal Form-->
          <div class="card card-warning card-outline mb-4"> <!--begin::Header-->
            <div class="card-header">
              <div class="card-title">Update baker</div>
            </div> <!--end::Header--> <!--begin::Form-->
            <form action="/api/user/{{user._id}}/update" method="post"> <!--begin::Body-->
              <div class="card-body">
                <div class="row mb-3"> <label for="name" class="col-sm-2 col-form-label">Name</label>
                  <div class="col-sm-10"> <input type="text" class="form-control" name="name" id="name" required
                      value="{{user.name}}"> </div>
                </div>
                <div class="row mb-3"> <label for="username" class="col-sm-2 col-form-label">Username</label>
                  <div class="col-sm-10"> <input type="text" name="username" class="form-control" id="username" required
                      value="{{user.username}}"> </div>
                </div>
                <div class="row mb-3"> <label for="username" class="col-sm-2 col-form-label">Delete</label>
                  <div class="col-sm-10"> <a type="submit" href="/api/user/{{user._id}}/delete"
                        class="btn btn-danger" name="save" value="create">Delete baker</a>  </div>
                </div>
              </div> <!--end::Body--> <!--begin::Footer-->
              <div class="card-footer"> <button type="submit" class="btn btn-warning">Update</button> <a
                  class="btn float-end" href="/api/user/{{user._id}}">Cancel</a> </div> <!--end::Footer-->
            </form> <!--end::Form-->
          </div> <!--end::Horizontal Form-->
        </div> <!--end::Col-->
      </div> <!--end::Row-->
    </div> <!--end::Container-->
  </div> <!--end::App Content-->
</main> <!--end::App Main-->

<script>
    let alert = document.getElementById('alert')
    setTimeout(() => {
        alert.style.display = "none"
    }, 3000)
</script>