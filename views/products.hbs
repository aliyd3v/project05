<!--begin::App Main-->
<main class="app-main"> <!--begin::App Content Header-->
    <div class="app-content-header"> <!--begin::Container-->
        <div class="container-fluid"> <!--begin::Row-->
            <div class="row">
                {{#if alert}}
                {{#if alert.success}}
                <div class="alert alert-success" id="alert" role="alert">
                    {{alert.message}}
                </div>
                {{else}}
                <div class="alert alert-danger" id="alert" role="alert">
                    {{alert.message}}
                </div>
                {{/if}}
                {{else}}
                {{/if}}
                <div class="col-md-6">
                    <h4>Products</h4>
                </div>
                <div class="col-md-6 text-end"> <a href="/api/create-product" class="btn btn-primary">Add product</a> </div>
            </div><!--end::Row-->
        </div> <!--end::Container-->
    </div> <!--end::App Content Header--> <!--begin::App Content-->
    <div class="app-content"> <!--begin::Container-->
        <div class="container-fluid"> <!--begin::Row-->
            <div class="row">
                <div class="card mb-4">
                    <div class="card-header">
                        <h3 class="card-title">Products list</h3>
                        <div class="card-tools">
                            <ul class="pagination pagination-sm float-end">
                                <li class="page-item"> <a class="page-link" href="#">&laquo;</a> </li>
                                <li class="page-item"> <a class="page-link" href="#">1</a> </li>
                                <li class="page-item"> <a class="page-link" href="#">&raquo;</a> </li>
                            </ul>
                        </div>
                    </div> <!-- /.card-header -->
                    <div class="card-body p-0">
                        <table class="table">
                            <thead>
                                {{#if products}}
                                <tr>
                                    <th style="width: 7%;">#</th>
                                    <th style="width: 20%; margin: 0 auto;">Name</th>
                                    <th style="width: 20%; margin: 0 auto;">Created at</th>
                                </tr>
                                {{/if}}
                            </thead>
                            <tbody>
                                {{#if products}}
                                {{#each products}}
                                <tr class="align-middle" id="{{id}}"
                                    style="{user-select: none; cursor: pointer;}">
                                    <td>{{number}}</td>
                                    <td><a href="/api/product/{{id}}"
                                            style="text-decoration:none; color: black;">{{name}}</a></td>
                                    <td>{{formatDate createdAt}}</td>
                                </tr>
                                {{/each}}
                                {{else}}
                                <p style="font-size: x-large; text-align: center;">Products is empty!</p>
                                {{/if}}
                            </tbody>
                        </table>
                    </div> <!-- /.card-body -->
                </div> <!-- /.card -->
            </div> <!--end::Row-->
        </div> <!--end::Container-->
    </div> <!--end::App Content-->
</main> <!--end::App Main-->

<script>
    let alert = document.getElementById('alert')
    setTimeout(() => {
        alert.style.display = "none"
    }, 3000)

    let userPage = document.querySelectorAll(".align-middle")
    userPage.forEach(item => {
        item.addEventListener('click', () => {
            window.location.href = `/api/product/${item.id}  `
        })

    })
</script>