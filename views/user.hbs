    
    <div class="one-user-container">
        <h2 class="one-user-title">User Details</h2>
        <div class="one-user-info" style="box-shadow: 0 0 3px black; height: 200px; width: 200px; border-radius: 5px; padding: 20px; margin: 50px auto;" >
            <div class="one-user-item">
                <span class="one-user-label">Name:</span>
                <span class="one-user-value">{{user.name}}</span>
            </div>
            <div class="one-user-item">
                <span class="one-user-label">Username:</span>
                <span class="one-user-value">{{user.username}}</span>
            </div>
        <div class="one-user-button-group"   style="margin-top: 50px; display: flex; justify-content: space-between;">
            <a style="padding: 5px 10px; border-radius: 5px; background-color: bisque; text-decoration:none ; color: black;" href="/api/user/{{user.id}}/update" class="one-user-edit-button">Edit</a>
            <a href="/api/users" style="padding: 5px 10px; border-radius: 5px; background-color: red; text-decoration:none ; color: black;" class="one-user-cancel-button">Cancel</a>
        </div>
        </div>
    </div>
