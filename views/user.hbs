    <div id="user-page">
        <div class="user-page-main-container">
            <div class="user-page-container">
                <h1 class="user-title">User Information</h1>
                <div class="user-info-container">
                    <h2 class="name">John Doe</h2>
                    <h2 class="username">john.doe</h2>
                </div>
                <div class="user-actions">
                    <button class="edit-btn">Edit</button>
                    <button class="delete-btn">Delete</button>
                    <button class="cancel-btn" style="display: none;">Cancel</button> <!-- Yashirin holatda -->
                </div>
                <div class="edit-form" style="display: none;"> <!-- Yashirin holatda -->
                    <input type="text" placeholder="New Username" />
                    <input type="text" placeholder="New Name" />
                    <input type="password" placeholder="New Password" /> <!-- Yangi input qo'shildi -->
                    <div class="edit-actions">
                        <button class="save-btn">Save</button>
                        <button class="cancel-save-btn">Cancel</button> <!-- Yana bir Cancel tugmasi -->
                    </div>
                </div>
                <div class="delete-confirmation" style="display: none;"> <!-- Yashirin holatda -->
                    <p class="confirmation-text">Are you sure you want to delete this user?</p>
                    <div class="delete-actions">
                        <button class="confirm-btn">Yes</button>
                        <button class="cancel-delete-btn">No</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>
<script>
    const editBtn = document.querySelector('.edit-btn');
    const deleteBtn = document.querySelector('.delete-btn');
    const cancelBtn = document.querySelector('.cancel-btn');
    const editForm = document.querySelector('.edit-form');
    const deleteConfirmation = document.querySelector('.delete-confirmation');

    // Edit tugmasini bosganda inputlar chiqadi
    editBtn.addEventListener('click', function() {
        editForm.style.display = 'block'; // Edit formni ko'rsatish
        deleteConfirmation.style.display = 'none'; // Delete tasdiqlashini yashirish
        editBtn.style.display = 'none'; // Edit tugmasini yashirish
        deleteBtn.style.display = 'none'; // Delete tugmasini yashirish
        cancelBtn.style.display = 'inline-block'; // Cancel tugmasini ko'rsatish
    });

    // Save tugmasini bosganda inputlarni saqlash
    document.querySelector('.save-btn').addEventListener('click', function() {
        const newUsername = editForm.querySelector('input[type="text"]').value;
        const newName = editForm.querySelectorAll('input[type="text"]')[1].value;
        const newPassword = editForm.querySelector('input[type="password"]').value; // Parolni oling
        document.querySelector('.username').textContent = newUsername;
        document.querySelector('.name').textContent = newName;
        editForm.style.display = 'none'; // Edit formni yopish
        editBtn.style.display = 'block'; // Edit tugmasini ko'rsatish
        deleteBtn.style.display = 'block'; // Delete tugmasini ko'rsatish
        cancelBtn.style.display = 'none'; // Cancel tugmasini yashirish
        // Parolni qo'shish, lekin faqat ko'rsatish uchun yoki boshqa jarayonlar
        console.log("New Password:", newPassword); // Yangi parolni konsolga chiqarish
    });

    // Delete tugmasini bosganda o'chirish tasdiqlovchi yozuv chiqadi
    deleteBtn.addEventListener('click', function() {
        deleteConfirmation.style.display = 'block'; // Tasdiqlashni ko'rsatish
        editForm.style.display = 'none'; // Edit formni yopish
        cancelBtn.style.display = 'none'; // Cancel tugmasini yashirish
    });

    // Delete tugmasi bosilganda rostan o'chirish
    document.querySelector('.confirm-btn').addEventListener('click', function() {
        alert('User has been deleted.'); // O'chirish tasdiqlovchi xabar
        // O'chirish jarayonini qo'shish
        deleteConfirmation.style.display = 'none'; // Tasdiqlashni yashirish
        editBtn.style.display = 'block'; // Edit tugmasini ko'rsatish
        deleteBtn.style.display = 'block'; // Delete tugmasini ko'rsatish
        cancelBtn.style.display = 'none'; // Cancel tugmasini yashirish
    });

    document.querySelector('.cancel-delete-btn').addEventListener('click', function() {
        deleteConfirmation.style.display = 'none'; // Tasdiqlashni yashirish
        editBtn.style.display = 'block'; // Edit tugmasini ko'rsatish
        deleteBtn.style.display = 'block'; // Delete tugmasini ko'rsatish
        cancelBtn.style.display = 'none'; // Cancel tugmasini yashirish
    });

    // Cancel tugmasini bosganda edit form yopiladi
    cancelBtn.addEventListener('click', function() {
        editForm.style.display = 'none'; // Edit formni yopish
        editBtn.style.display = 'block'; // Edit tugmasini ko'rsatish
        deleteBtn.style.display = 'block'; // Delete tugmasini ko'rsatish
        cancelBtn.style.display = 'none'; // Cancel tugmasini yashirish
    });

    // Cancel tugmasini bosganda edit form yopiladi
    document.querySelector('.cancel-save-btn').addEventListener('click', function() {
        editForm.style.display = 'none'; // Edit formni yopish
    });
</script>