<div class="table-container">
    <h2>Materials</h2>
    <table>
        <thead>
            <tr>
                <th>Material Name</th>
                <th>Quantity</th>
            </tr>
        </thead>
        <tbody>
            {{#each material}}
            <tr>
                <td>
                    <a href="/api/material/{{id}}" class="material-link">{{name}}</a>
                </td>
                <td>{{quantity}}</td>
            </tr>
            {{/each}}
        </tbody>
    </table>
</div>
