<!--begin::App Main-->
<main class="app-main"> <!--begin::App Content Header-->
    <div class="app-content-header"> <!--begin::Container-->
        <div class="container-fluid"> <!--begin::Row-->
            <div class="row">
                {{#if alert}}
                {{#if alert.success}}
                <div class="alert alert-success" id="alert" role="alert">
                    {{alert.message}}
                </div>
                {{else}}
                <div class="alert alert-danger" id="alert" role="alert">
                    {{alert.message}}
                </div>
                {{/if}}
                {{else}}
                {{/if}}
            </div> <!--end::Row-->
        </div> <!--end::Container-->
    </div> <!--end::App Content Header--> <!--begin::App Content-->
    <div class="app-content"> <!--begin::Container-->
        <div class="container-fluid"> <!--begin::Row-->
            <div class="row g-4"> <!--begin::Col-->
                <div class="col-md-6"> <!--begin::Horizontal Form-->
                    <div class="card card-warning card-outline mb-4"> <!--begin::Header-->
                        <div class="card-header">
                            <div class="card-title">Product</div>
                        </div> <!--end::Header--> <!--begin::div-->
                        <div> <!--begin::Body-->
                            <div class="card-body">
                                <div class="row mb-3"> <label for="name" class="col-sm-2 col-form-label">Name</label>
                                    <div class="col-sm-10"> <input type="text" class="form-control" id="name"
                                            value="{{data.name}}" disabled> </div>
                                </div>
                                <div class="row mb-3"> <label for="createdAt" class="col-sm-2 col-form-label">Created
                                        at</label>
                                    <div class="col-sm-10">
                                        <p type="date" class="form-control" id="createdAt" disabled> {{formatDate
                                            data.createdAt}}
                                    </div>
                                </div>
                                <div class="row mb-3">
                                    <div class="app-content"> <!--begin::Container-->
                                        <div class="container-fluid"> <!--begin::Row-->
                                            <div class="row">
                                                <div class="card mb-4">
                                                    <div class="card-header">
                                                        <h4 class="card-title">Used materials list</h4>
                                                        <div class="card-tools">
                                                        </div>
                                                    </div> <!-- /.card-header -->
                                                    <div class="card-body p-0">
                                                        <table class="table">
                                                            <thead>
                                                                {{#if data.materialsUsed}}
                                                                <tr>
                                                                    <th style="width: 20%; margin: 0 auto;">Material
                                                                        name</th>
                                                                    <th style="width: 20%; margin: 0 auto;">Amount used
                                                                    </th>
                                                                </tr>
                                                                {{/if}}
                                                            </thead>
                                                            <tbody>
                                                                {{#if data.materialsUsed}}
                                                                {{#each data.materialsUsed}}
                                                                <tr class="align-middle" id="{{id}}"
                                                                    style="{user-select: none; cursor: pointer;}">
                                                                    <td>{{name}}</td>
                                                                    <td>{{amount}} gr</td>
                                                                </tr>
                                                                {{/each}}
                                                                {{else}}
                                                                <p style="font-size: x-large; text-align: center;">
                                                                    Products is empty!</p>
                                                                {{/if}}
                                                            </tbody>
                                                        </table>
                                                    </div> <!-- /.card-body -->
                                                </div> <!-- /.card -->
                                            </div> <!--end::Row-->
                                        </div> <!--end::Container-->
                                    </div> <!--end::App Content-->
                                </div>
                            </div> <!--end::Body--> <!--begin::Footer-->
                            <div class="card-footer"> <a type="submit" href="/api/product/{{data._id}}/update"
                                    class="btn btn-warning">Edit</a> <a type="submit" href="/api/products"
                                    class="btn float-end">Cancel</a> </div> <!--end::Footer-->
                        </div> <!--end::div-->
                    </div> <!--end::Horizontal Form-->
                </div> <!--end::Col-->
            </div> <!--end::Row-->
        </div> <!--end::Container-->
    </div> <!--end::App Content-->
</main> <!--end::App Main-->

<script>
    let alert = document.getElementById('alert')
    setTimeout(() => {
        alert.style.display = "none"
    }, 3000)
</script>