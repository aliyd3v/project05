<main class="app-main"> <!--begin::App Content Header-->
    <div class="app-content-header">  <!--begin::Container-->
        <div class="container-fluid"> <!--begin::Row-->
            <div class="row">
                {{#if alert}}
                {{#if alert.success}}
                <div class="alert alert-success" id="alert" role="alert">
                    {{alert.message}}
                </div>
                {{else}}
                <div class="alert alert-danger" id="alert" role="alert">
                    {{alert.message}}
                </div>
                {{/if}}
                {{else}}
                {{/if}}
            </div>
        </div>
    </div>
    <div class="app-content">
        <div class="container-fluid">
            <div class="row g-4"> <!--begin::Col-->
                <div class="col-md-6">
                    <!--begin::Create Material Form-->
                    <div class="card card-warning card-outline mb-4"> <!--begin::Header-->
                        <div class="card-header">
                            <div class="card-title">Create New Material</div>
                        </div> <!--end::Header-->
                        <!--begin::Form-->
                        <form id="create-form" action="/api/create-material" method="POST"> <!--begin::Body-->
                            <div class="card-body">
                                <div class="row mb-3">
                                    <label for="name" class="col-sm-2 col-form-label">Name</label>
                                    <div class="col-sm-10">
                                        <input type="text" class="form-control" id="name" name="name" required>
                                    </div>
                                </div>
                                <div class="row mb-3">
                                    <label for="quantity" class="col-sm-2 col-form-label">Quantity</label>
                                    <div class="col-sm-10">
                                        <input type="number" class="form-control" id="quantity" name="quantity"
                                            required>
                                    </div>
                                </div>
                            </div> <!--end::Body-->
                            <!--begin::Footer-->
                            <div class="card-footer">
                                <button type="submit" class="btn btn-warning">Create</button>
                                <a href="/api/materials" class="btn float-end">Cancel</a>
                            </div> <!--end::Footer-->
                        </form> <!--end::Form-->
                    </div> <!--end::Create Material Form-->
                </div> <!--end::Col-->
            </div> <!--end::Row-->
        </div> <!--end::App Content-->
    </div>
</main>

<script>
    let alert = document.getElementById('alert')
    setTimeout(() => {
        alert.style.display = "none"
    }, 3000)
</script>